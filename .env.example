# ── Base de données ────────────────────────────────────────────────
POSTGRES_USER=mailarchiver
POSTGRES_PASSWORD=change-me
POSTGRES_DB=mailarchiver
DATABASE_URL=postgresql+asyncpg://mailarchiver:change-me@postgres:5432/mailarchiver

# ── File de messages (RabbitMQ) ────────────────────────────────────
RABBITMQ_DEFAULT_USER=mailarchiver
RABBITMQ_DEFAULT_PASS=change-me
AMQP_URL=amqp://mailarchiver:change-me@rabbitmq:5672/
RAW_MAIL_QUEUE=raw_mail

# ── Stockage objet (MinIO / S3) ────────────────────────────────────
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change-me
S3_BUCKET=archives
S3_REGION=us-east-1
# WORM (archivage immuable) : jours d'immuabilité des blobs (0 = désactivé).
# Doit couvrir DEFAULT_RETENTION_DAYS. Mode GOVERNANCE (contournable avec droit) ou COMPLIANCE.
S3_OBJECT_LOCK_DAYS=365
S3_OBJECT_LOCK_MODE=GOVERNANCE

# ── Index de recherche (OpenSearch) ────────────────────────────────
OPENSEARCH_URL=http://opensearch-node1:9200
OPENSEARCH_INDEX=messages
OPENSEARCH_HEAP=512m
OPENSEARCH_SHARDS=2
OPENSEARCH_REPLICAS=1

# ── SMTP gateway ───────────────────────────────────────────────────
SMTP_HOST=0.0.0.0
SMTP_PORT=2525
SMTP_TLS_CERT=/secrets/smtp_cert.pem
SMTP_TLS_KEY=/secrets/smtp_key.pem
SMTP_REQUIRE_STARTTLS=false
SMTP_MAX_MESSAGE_BYTES=52428800

# ── Cryptographie ──────────────────────────────────────────────────
# Clé maître AES-256 (32 octets en base64) — voir `make keys`
MASTER_KEY_FILE=/secrets/master.key
# Paire de signature Ed25519 (PEM) — voir `make keys`
SIGNING_PRIVATE_KEY_FILE=/secrets/signing_private.pem
SIGNING_PUBLIC_KEY_FILE=/secrets/signing_public.pem

# ── API web ────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# Clé de signature JWT. EN PRODUCTION : `make secret-key` puis coller ici.
API_SECRET_KEY=change-me-session-jwt
SESSION_TTL_HOURS=8
DEFAULT_LOCALE=fr
SUPPORTED_LOCALES=fr,en,de,es

# Durcissement connexion (verrouillage anti-bruteforce)
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Journalisation (structlog)
LOG_LEVEL=INFO
LOG_JSON=false

# ── Compte administrateur local par défaut ─────────────────────────
# Disponible même sans LDAP. À CHANGER en production.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# ── Authentification AD / LDAP ─────────────────────────────────────
LDAP_ENABLED=false
LDAP_SERVER=ldaps://dc.example.com:636
LDAP_BASE_DN=DC=example,DC=com
LDAP_USER_DN_TEMPLATE=uid={username},OU=Users,DC=example,DC=com
LDAP_ADMIN_GROUP=CN=ArchiveAdmins,OU=Groups,DC=example,DC=com

# ── Rétention ──────────────────────────────────────────────────────
# Durée par défaut en jours (0 = conservation illimitée)
DEFAULT_RETENTION_DAYS=3650
RETENTION_SCAN_CRON=0 2 * * *

# ── Forward SMTP (relais sortant pour le transfert de mails) ───────
FORWARD_SMTP_HOST=smtp.example.com
FORWARD_SMTP_PORT=587
FORWARD_SMTP_USER=
FORWARD_SMTP_PASSWORD=
FORWARD_SMTP_STARTTLS=true
