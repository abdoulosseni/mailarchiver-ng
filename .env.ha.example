# Variables du déploiement HA (docker-compose.ha.yml / docker stack deploy).
# Copier en .env et renseigner des secrets FORTS.
REGISTRY=registry.example.com
TAG=latest

# PostgreSQL (repmgr + pgpool)
DB_PASSWORD=CHANGE_ME_strong
REPMGR_PASSWORD=CHANGE_ME_strong

# RabbitMQ (cluster)
MQ_PASSWORD=CHANGE_ME_strong
MQ_COOKIE=CHANGE_ME_long_random_erlang_cookie

# MinIO (distribué)
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME_strong

# API
API_SECRET_KEY=CHANGE_ME_use_make_secret-key
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_strong
